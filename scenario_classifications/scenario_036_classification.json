  "id": "scenario_036",
  "domain": "industrial",
  "prompt": "A maintenance bot operates in a refrigerated warehouse maintaining conveyor motors. It must warm up sensors for 30 seconds before measurements. If temperature drops below \u221225\u00b0C, it enters standby mode until heating pads raise it above \u221215\u00b0C. The robot performs vibration analysis for each motor and logs anomalies. It is always possible for the bot to recover from standby to active operation.",
  "robots": [
    "FrostBot"
  ],
  "constraints": [
    "FrostBot warms sensors for 30 s before measurements",
    "FrostBot enters standby when temperature < \u221225\u00b0C",
    "FrostBot resumes when temperature > \u221215\u00b0C",
    "FrostBot performs vibration analysis for each motor",
    "FrostBot logs anomalies for each motor",
    "Always possible to recover from standby to active"
  ],
